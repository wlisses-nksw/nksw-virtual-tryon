{
  "version": 2,
  "functions": {
    "api/submit.js": { "maxDuration": 60 },
    "api/result.js":  { "maxDuration": 10 },
    "api/lead.js":    { "maxDuration": 10 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
